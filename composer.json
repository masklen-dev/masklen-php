{
  "name": "masklen/masklen",
  "description": "Official PHP SDK for the masklen.dev IP intelligence API",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Masklen\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Masklen\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  }
}
